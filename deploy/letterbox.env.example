# /etc/default/letterbox — copy to /etc/default/letterbox on liu and
# fill in LETTERBOX_ADMIN_KEY with a real secret. systemd loads this
# via EnvironmentFile= in letterbox.service.

LETTERBOX_ADDR=172.18.0.1:3737
LETTERBOX_DB=/home/liu/infra/pointegrityws/data/letterbox.db
LETTERBOX_REDIRECT=https://www.pointegrity.com
LETTERBOX_ADMIN_KEY=replace-with-32+-random-bytes
